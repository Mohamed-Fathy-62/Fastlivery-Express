{
  "info": {
    "_postman_id": "5a7e6a47-f4c0-41e6-8f40-3c46bce74031",
    "name": "Fastlivery Express - Shipment Service",
    "description": "Postman collection for the Fastlivery Express shipment microservice, including quote/request, confirm, and CRUD endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Order Flow",
      "item": [
        {
          "name": "Request Shipment Quote and Assign Driver",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.shipment && json.shipment.id) {",
                  "    pm.collectionVariables.set('shipmentId', json.shipment.id);",
                  "  }",
                  "  if (json.shipment && json.shipment.trackingNumber) {",
                  "    pm.collectionVariables.set('trackingNumber', json.shipment.trackingNumber);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"originAddress\": \"Nasr City, Cairo\",\n  \"destinationAddress\": \"Maadi, Cairo\",\n  \"originLatitude\": {{originLatitude}},\n  \"originLongitude\": {{originLongitude}},\n  \"destinationLatitude\": {{destinationLatitude}},\n  \"destinationLongitude\": {{destinationLongitude}},\n  \"totalWeight\": 2.5,\n  \"packageDetails\": \"Small fragile package\",\n  \"packageDimensions\": \"30x20x15 cm\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/shipments/request",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "shipments",
                "request"
              ]
            },
            "description": "Calculates price through pricing service, finds nearest available driver through user service, and creates a PENDING_CONFIRMATION shipment."
          },
          "response": []
        },
        {
          "name": "Confirm Shipment",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/shipments/{{shipmentId}}/confirm",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "shipments",
                "{{shipmentId}}",
                "confirm"
              ]
            },
            "description": "Confirms a PENDING_CONFIRMATION shipment and marks the assigned driver unavailable."
          },
          "response": []
        },
        {
          "name": "Create Stripe Checkout Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.checkoutSessionId) {",
                  "    pm.collectionVariables.set('stripeCheckoutSessionId', json.checkoutSessionId);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/shipments/{{shipmentId}}/payment/checkout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "shipments",
                "{{shipmentId}}",
                "payment",
                "checkout"
              ]
            },
            "description": "Creates a Stripe Checkout Session and returns the hosted checkout URL."
          },
          "response": []
        },
        {
          "name": "Sync Stripe Checkout Session",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/shipments/payment/sync?session_id={{stripeCheckoutSessionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "shipments",
                "payment",
                "sync"
              ],
              "query": [
                {
                  "key": "session_id",
                  "value": "{{stripeCheckoutSessionId}}"
                }
              ]
            },
            "description": "Retrieves a Stripe Checkout Session and updates shipment paymentStatus."
          },
          "response": []
        },
        {
          "name": "Track Shipment by Tracking Number",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/shipments/track/{{trackingNumber}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "shipments",
                "track",
                "{{trackingNumber}}"
              ]
            },
            "description": "Returns shipment status, ETA, last known location, and assigned driver's latest location."
          },
          "response": []
        }
      ]
    },
