          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trackingNumber\": \"{{trackingNumber}}\",\n  \"customerId\": \"{{customerId}}\",\n  \"driverId\": \"{{driverId}}\",\n  \"originAddress\": \"Nasr City, Cairo\",\n  \"destinationAddress\": \"Maadi, Cairo\",\n  \"originLatitude\": {{originLatitude}},\n  \"originLongitude\": {{originLongitude}},\n  \"destinationLatitude\": {{destinationLatitude}},\n  \"destinationLongitude\": {{destinationLongitude}},\n  \"status\": \"PENDING_CONFIRMATION\",\n  \"totalPrice\": 120.50,\n  \"estimatedDeliveryTime\": \"2026-05-17T22:30:00\",\n  \"actualDeliveryTime\": null,\n  \"packageDetails\": \"Small fragile package\",\n  \"paymentStatus\": \"PENDING\",\n  \"customerFeedback\": null,\n  \"customerRating\": null,\n  \"driverFeedback\": null,\n  \"driverRating\": null,\n  \"cancellationReason\": null,\n  \"lastKnownLocation\": \"Nasr City, Cairo\",\n  \"totalWeight\": 2.5,\n  \"packageDimensions\": \"30x20x15 cm\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/shipments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "shipments"
              ]
            },
            "description": "Creates a shipment directly without calling pricing or nearest-driver assignment."
          },
          "response": []
