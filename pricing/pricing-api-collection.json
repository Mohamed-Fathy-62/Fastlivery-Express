  "item": [
    {
      "name": "Quotes",
      "item": [
        {
          "name": "Calculate Total Price",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coordinates\": [\n    [{{originLongitude}}, {{originLatitude}}],\n    [{{destinationLongitude}}, {{destinationLatitude}}]\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/pricing/calculate?weight={{weight}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pricing",
                "calculate"
              ],
              "query": [
                {
                  "key": "weight",
                  "value": "{{weight}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Calculate Detailed Quote",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coordinates\": [\n    [{{originLongitude}}, {{originLatitude}}],\n    [{{destinationLongitude}}, {{destinationLatitude}}]\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/pricing/quote?weight={{weight}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pricing",
                "quote"
              ],
              "query": [
                {
                  "key": "weight",
                  "value": "{{weight}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pricing Configs",
      "item": [
        {
          "name": "Create Pricing Config",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.id) pm.collectionVariables.set('pricingId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"baseFare\": 25.0,\n  \"ratePerKm\": 6.0,\n  \"ratePerKg\": 4.0,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/pricing/configs",
              "host": [
                "{{baseUrl}}"
